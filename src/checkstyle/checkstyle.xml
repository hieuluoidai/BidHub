<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Google Java Style Guide – adapted for BidHub (4-space indent).
  Key rules enforced:
    §3.3.1  No wildcard imports
    §4.1    Braces: K&R style (left brace at end of line)
    §4.4    Column limit: 130 (relaxed from Google's 100)
    §5      Naming conventions
  JavadocMethod and IndentationCheck are omitted intentionally.
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- §4.4 Column limit (130 instead of Google's 100 for readability with long SQL) -->
    <module name="LineLength">
        <property name="max" value="130"/>
        <property name="ignorePattern" value="^package.*|^import.*"/>
    </module>

    <!-- Exclude module-info.java (JPMS descriptor, TreeWalker cannot parse it) -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="module-info\.java$"/>
    </module>

    <!-- No tab characters in source files -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <module name="TreeWalker">

        <!-- §3.3.1 No wildcard imports -->
        <module name="AvoidStarImport"/>
        <module name="RedundantImport"/>
        <module name="UnusedImports"/>

        <!-- §5 Naming conventions -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>
        <module name="TypeName"/>
        <module name="MethodName"/>
        <module name="MemberName"/>
        <!-- Allow serialVersionUID (lowercase) alongside UPPER_SNAKE_CASE constants -->
        <module name="ConstantName">
            <property name="format" value="^serialVersionUID$|^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>
        <module name="LocalVariableName"/>
        <module name="ParameterName"/>

        <!-- §4.1 Braces: K&R style — opening brace must be at end of line -->
        <module name="LeftCurly"/>
        <module name="RightCurly"/>
        <!-- for/while/do loops always require braces -->
        <module name="NeedBraces">
            <property name="tokens" value="LITERAL_DO, LITERAL_FOR, LITERAL_WHILE"/>
        </module>

        <!-- Structural rules -->
        <module name="OuterTypeFilename"/>
        <module name="OneTopLevelClass"/>
        <module name="NoFinalizer"/>

        <!-- Disallow confusing 0l/0L integer literals -->
        <module name="IllegalTokenText">
            <property name="tokens" value="NUM_INT,NUM_LONG"/>
            <property name="format" value="^0[lL]$"/>
            <property name="message" value="Avoid 0l or 0L, use 0 instead."/>
        </module>

    </module>
</module>
