<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="mainContainer" maxHeight="Infinity" maxWidth="Infinity" minWidth="800.0" spacing="0" styleClass="card, item-details-card" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ItemDetailsController">
    <children>
        <VBox spacing="6.0" styleClass="item-details-header">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Label fx:id="lblItemName" maxWidth="Infinity" styleClass="label-header" text="Tên sản phẩm" wrapText="true" HBox.hgrow="ALWAYS" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblCategory" alignment="CENTER" minWidth="96.0" styleClass="details-category-chip" text="Item" />
                    </children>
                </HBox>
                <HBox fx:id="extraInfoContainer" spacing="10.0" alignment="CENTER_LEFT" />
            </children>
        </VBox>

        <Separator />

        <ScrollPane fx:id="detailsScrollPane" fitToWidth="true" styleClass="auction-scroll-pane" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="22.0" styleClass="item-details-content">
                    <children>
                        <VBox fx:id="paneAntiSnipeNotif" alignment="CENTER" managed="false" spacing="5.0" styleClass="anti-snipe-banner" visible="false">
                            <children>
                                <Label styleClass="anti-snipe-text" text="⏰ ANTI-SNIPING: Thời gian đấu giá vừa được gia hạn thêm!" wrapText="true" />
                            </children>
                        </VBox>
                        <GridPane hgap="22.0" vgap="22.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="37.0" />
                                <ColumnConstraints percentWidth="63.0" />
                            </columnConstraints>
                            <children>
                                <VBox spacing="14.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <StackPane styleClass="details-image-shell">
                                            <children>
                                                <VBox fx:id="noImagePlaceholder" alignment="CENTER" spacing="12.0" styleClass="no-image-placeholder">
                                                    <children>
                                                        <javafx.scene.shape.SVGPath content="M21 15V19C21 20.1046 20.1046 21 19 21H5C3.89543 21 3 20.1046 3 19V5C3 3.89543 3.89543 3 5 3H19C20.1046 3 21 3.89543 21 5V9M21 15L15.9142 9.91421C15.1332 9.13317 13.8668 9.13317 13.0858 9.91421L11.5 11.5M21 15L19.4142 13.4142C18.6332 12.6332 17.3668 12.6332 16.5858 13.4142L11.5 18.5M11.5 11.5L6.41421 16.5858C5.63316 17.3668 4.36683 17.3668 3.58579 16.5858L3 16M15 6.5C15 7.32843 14.3284 8 13.5 8C12.6716 8 12 7.32843 12 6.5C12 5.67157 12.6716 5 13.5 5C14.3284 5 15 5.67157 15 6.5Z" fill="TRANSPARENT" stroke="#94A3B8" strokeWidth="2.0" strokeLineCap="ROUND" strokeLineJoin="ROUND" scaleX="2.0" scaleY="2.0"/>
                                                        <Label text="Chưa có hình ảnh" styleClass="no-image-text" />
                                                    </children>
                                                </VBox>
                                                <ImageView fx:id="itemImageView" fitHeight="292.0" fitWidth="360.0" pickOnBounds="true" preserveRatio="true" />
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>

                                <VBox spacing="14.0" styleClass="details-panel" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <children>
                                        <Label styleClass="details-section-title" text="Mô tả sản phẩm" />
                                        <TextArea fx:id="txtDescription" editable="false" prefHeight="191.0" prefWidth="350.0" styleClass="text-area details-description" wrapText="true" />
                                    </children>
                                </VBox>

                                <VBox spacing="14.0" styleClass="details-panel chart-panel" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label styleClass="details-section-title" text="↗ Diễn biến giá trực tuyến" />
                                                <Label text="LIVE" styleClass="live-badge">
                                                    <graphic>
                                                        <javafx.scene.shape.Circle radius="3" fill="#EF4444" styleClass="live-dot" />
                                                    </graphic>
                                                </Label>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblHighestBidder" styleClass="details-muted-text" text="Chưa có ai dẫn đầu" />
                                            </children>
                                        </HBox>

                                        <AreaChart fx:id="bidChart" animated="false" createSymbols="true" legendVisible="false" prefHeight="270.0" styleClass="bid-chart">
                                            <xAxis>
                                                <NumberAxis fx:id="bidXAxis" forceZeroInRange="false" minorTickVisible="false" tickLabelsVisible="false" tickMarkVisible="false" />
                                            </xAxis>
                                            <yAxis>
                                                <NumberAxis fx:id="bidYAxis" forceZeroInRange="false" minorTickVisible="false" />
                                            </yAxis>
                                        </AreaChart>

                                        <GridPane hgap="12.0" styleClass="bid-stat-grid">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="23.0" />
                                                <ColumnConstraints percentWidth="23.0" />
                                                <ColumnConstraints percentWidth="14.0" />
                                                <ColumnConstraints percentWidth="40.0" />
                                            </columnConstraints>
                                            <children>
                                                <VBox maxWidth="Infinity" styleClass="bid-stat-card" GridPane.columnIndex="0">
                                                    <children>
                                                        <Label styleClass="bid-stat-label" text="Giá khởi điểm" wrapText="false" />
                                                        <Label fx:id="lblStartingPrice" styleClass="bid-stat-value" text="0 ₫" wrapText="false" />
                                                    </children>
                                                </VBox>
                                                <VBox maxWidth="Infinity" styleClass="bid-stat-card-current" GridPane.columnIndex="1">
                                                    <children>
                                                        <Label styleClass="bid-stat-label" text="Giá hiện tại" wrapText="false" />
                                                        <Label fx:id="lblCurrentPrice" styleClass="bid-stat-value" text="0 ₫" wrapText="false" />
                                                    </children>
                                                </VBox>
                                                <VBox maxWidth="Infinity" styleClass="bid-stat-card" GridPane.columnIndex="2">
                                                    <children>
                                                        <Label styleClass="bid-stat-label" text="Số lần đặt" wrapText="false" />
                                                        <Label fx:id="lblBidCount" styleClass="bid-stat-value" text="0" wrapText="false" />
                                                    </children>
                                                </VBox>
                                                <VBox maxWidth="Infinity" styleClass="bid-stat-card, bid-stat-card-end" GridPane.columnIndex="3">
                                                    <children>
                                                        <Label styleClass="bid-stat-label" text="Thời gian còn lại" wrapText="false" />
                                                        <Label fx:id="lblCountdown" maxWidth="Infinity" styleClass="bid-stat-value, bid-stat-countdown" text="--:--:--" wrapText="false" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </GridPane>

                                        <ProgressBar fx:id="progressTimeBar" maxWidth="Infinity" prefHeight="6.0" progress="1.0" styleClass="time-progress-bar" />

                                        <VBox fx:id="paneWinner" managed="false" spacing="12.0" style="-fx-background-color: linear-gradient(to bottom right, #ECFDF5, #D1FAE5); -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #10B981; -fx-border-width: 2; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(16, 185, 129, 0.2), 10, 0, 0, 5);" visible="false">
                                            <children>
                                                <HBox alignment="CENTER" spacing="15.0">
                                                    <children>
                                                        <Label style="-fx-font-size: 24px;" text="🏆" />
                                                        <VBox alignment="CENTER_LEFT" spacing="2.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 14px; -fx-text-fill: #065F46; -fx-font-weight: bold;" text="CHÚC MỪNG NGƯỜI CHIẾN THẮNG" />
                                                                <Label fx:id="lblWinnerName" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #047857;" text="-" />
                                                            </children>
                                                        </VBox>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                                
                                                <VBox fx:id="panePayWinner" managed="false" spacing="10.0" visible="false">
                                                    <children>
                                                        <Separator style="-fx-opacity: 0.3;" />
                                                        <Label style="-fx-text-fill: #065F46; -fx-font-size: 13px;" text="Bạn đã thắng phiên đấu giá này! Vui lòng hoàn tất thanh toán để nhận sản phẩm." wrapText="true" />
                                                        <Button fx:id="btnPay" maxWidth="Infinity" mnemonicParsing="false" onAction="#handlePay" prefHeight="50.0" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 16px; -fx-background-radius: 8; -fx-cursor: hand;" text="THANH TOÁN NGAY" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox spacing="14.0" styleClass="details-panel bidding-panel" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <children>
                                                <Label styleClass="details-section-title" text="Khu đấu giá" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label styleClass="details-muted-text" text="Bid gần nhất:" />
                                                <Label fx:id="lblBidTime" styleClass="details-strong-text" text="-" />
                                            </children>
                                        </HBox>

                                        <StackPane VBox.vgrow="ALWAYS">
                                            <children>
                                                <VBox fx:id="biddingContent" spacing="14.0">
                                                    <children>
                                                        <HBox alignment="CENTER" styleClass="segmented-control">
                                                            <fx:define>
                                                                <ToggleGroup fx:id="bidTypeGroup" />
                                                            </fx:define>
                                                            <children>
                                                                <ToggleButton fx:id="tglManualBid" selected="true" styleClass="segment-button, segment-left" text="Đấu giá thủ công" toggleGroup="$bidTypeGroup" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                                                <ToggleButton fx:id="tglAutoBid" styleClass="segment-button, segment-right" text="Đấu giá tự động" toggleGroup="$bidTypeGroup" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                                            </children>
                                                        </HBox>

                                                        <StackPane>
                                                            <children>
                                                                <VBox fx:id="paneManualBid" spacing="12.0">
                                                                    <children>
                                                                        <Button fx:id="btnOpenBid" maxWidth="Infinity" onAction="#handleOpenBidDialog" prefHeight="48.0" styleClass="button-primary" text="ĐẶT GIÁ NGAY" />
                                                                    </children>
                                                                </VBox>

                                                                <VBox fx:id="paneAutoBid" managed="false" spacing="12.0" styleClass="autobid-panel" visible="false">
                                                                    <children>
                                                                        <HBox spacing="12.0">
                                                                            <children>
                                                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                                                    <children>
                                                                                        <Label styleClass="form-label" text="Giá tối đa bạn sẵn sàng trả" />
                                                                                        <TextField fx:id="txtAutoMaxBid" promptText="VD: 500.00" styleClass="text-field" />
                                                                                    </children>
                                                                                </VBox>
                                                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                                                    <children>
                                                                                        <Label styleClass="form-label" text="Mỗi bước tăng thêm" />
                                                                                        <TextField fx:id="txtAutoIncrement" promptText="VD: 10.00" styleClass="text-field" />
                                                                                    </children>
                                                                                </VBox>
                                                                            </children>
                                                                        </HBox>

                                                                        <HBox spacing="10.0">
                                                                            <children>
                                                                                <Button fx:id="btnSetAutoBid" maxWidth="Infinity" onAction="#handleSetAutoBid" prefHeight="40.0" style="-fx-background-color: #6366F1;" styleClass="button-primary" text="Kích hoạt Auto-Bid" HBox.hgrow="ALWAYS" />
                                                                                <Button fx:id="btnCancelAutoBid" managed="false" onAction="#handleCancelAutoBid" prefHeight="40.0" styleClass="button-danger" text="Hủy Auto-Bid" visible="false" />
                                                                            </children>
                                                                        </HBox>
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </StackPane>
                                                    </children>
                                                </VBox>

                                                <VBox fx:id="paneNoPermission" alignment="CENTER" managed="false" spacing="12.0" styleClass="no-permission-pane" visible="false">
                                                    <children>
                                                        <Label fx:id="lblNoPermission" styleClass="no-permission-text" text="Chỉ người mua (Bidder) mới có quyền tham gia đấu giá tại phiên này." wrapText="true" />
                                                    </children>
                                                </VBox>

                                                <VBox fx:id="paneStatusMessage" alignment="CENTER" managed="false" spacing="12.0" styleClass="no-permission-pane" visible="false">
                                                    <children>
                                                        <Label fx:id="lblStatusMessage" styleClass="no-permission-text" text="Phiên đấu giá chưa bắt đầu hoặc đã kết thúc." wrapText="true" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <VBox spacing="12.0" styleClass="details-panel history-panel">
                            <children>
                                <Label styleClass="details-section-title" text="Lịch sử đấu giá" />
                                <ListView fx:id="bidHistoryList" prefHeight="300.0" styleClass="modern-bid-list" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <Separator />

        <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="item-details-footer">
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="40.0" prefWidth="100.0" styleClass="button-secondary" text="Đóng" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10.0">
                    <children>
                        <Button fx:id="btnAddFriend" managed="false" visible="false" mnemonicParsing="false" onAction="#handleFriendAction" prefHeight="40.0" styleClass="button-secondary" text="+ Kết bạn" />
                        <Button fx:id="btnChatSeller" managed="false" visible="false" mnemonicParsing="false" onAction="#handleChatSeller" prefHeight="40.0" styleClass="button-secondary" text="💬 Nhắn tin" />
                        <Button fx:id="btnEdit" managed="false" mnemonicParsing="false" onAction="#handleEdit" prefHeight="40.0" styleClass="button-secondary" text="Sửa" visible="false" />
                        <Button fx:id="btnCancel" managed="false" mnemonicParsing="false" onAction="#handleCancelAuction" prefHeight="40.0" styleClass="button-danger" text="Hủy phiên" visible="false" />
                        <Button fx:id="btnDelete" managed="false" mnemonicParsing="false" onAction="#handleOpenDelete" prefHeight="40.0" styleClass="button-danger-confirm" text="Xóa" visible="false" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </children>
</VBox>
