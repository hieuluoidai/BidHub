<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ItemDetailsController">
    <children>
        <VBox maxHeight="600.0" maxWidth="500.0" prefWidth="480.0" spacing="15.0" styleClass="card">
            <children>
                <Label fx:id="lblItemName" styleClass="label-header" text="Tên sản phẩm" wrapText="true">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <VBox spacing="8.0">
                    <children>
                        <HBox spacing="5.0">
                            <Label styleClass="form-label" text="Thể loại:" />
                            <Label fx:id="lblCategory" text="Item" style="-fx-text-fill: #475569;" />
                        </HBox>
                        <HBox spacing="5.0">
                            <Label fx:id="lblExtraInfo" text="Thông tin thêm sẽ hiện ở đây" style="-fx-text-fill: #475569; -fx-font-style: italic;" />
                        </HBox>
                    </children>
                </VBox>

                <Separator>
                    <VBox.margin>
                        <Insets bottom="5.0" top="5.0" />
                    </VBox.margin>
                </Separator>

                <VBox spacing="10.0" style="-fx-background-color: #F8FAFC; -fx-padding: 15; -fx-background-radius: 10;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="form-label" text="Giá hiện tại:">
                                <font>
                                    <Font size="16.0" />
                                </font>
                            </Label>
                            <Label fx:id="lblCurrentPrice" styleClass="label-price" text="0.0 VNĐ" />
                        </HBox>
        
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="form-label" text="Dẫn đầu:" />
                            <Label fx:id="lblHighestBidder" text="Chưa có ai" style="-fx-text-fill: #1E293B; -fx-font-weight: bold;" />
                        </HBox>
        
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="form-label" text="Cập nhật lúc:" />
                            <Label fx:id="lblBidTime" text="-" style="-fx-text-fill: #64748B; -fx-font-style: italic;" />
                        </HBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label styleClass="form-label" text="Kết thúc lúc:" />
                        <Label fx:id="lblEndTime" styleClass="badge-urgent" text="12/34/56 12:34:56" />
                    </children>
                </HBox>

                <TextArea fx:id="txtDescription" editable="false" prefHeight="100.0" styleClass="text-area" wrapText="true" />
                
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="44.0" prefWidth="90.0" styleClass="button-secondary" text="Đóng" />
                        
                        <Button fx:id="btnEdit" managed="false" mnemonicParsing="false" onAction="#handleEdit" prefHeight="44.0" prefWidth="70.0" styleClass="button-secondary" text="Sửa" visible="false" />
                        <Button fx:id="btnDelete" managed="false" mnemonicParsing="false" onAction="#handleOpenDelete" prefHeight="44.0" prefWidth="70.0" styleClass="button-danger" text="Xóa" visible="false" />
                        
                        <Button fx:id="btnOpenBid" maxWidth="Infinity" onAction="#handleOpenBidDialog" prefHeight="44.0" styleClass="button-primary" text="Tham gia đấu giá ngay!" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</StackPane>