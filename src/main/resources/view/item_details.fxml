<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ItemDetailsController">
    <children>
        <VBox maxHeight="860.0" maxWidth="1180.0" prefWidth="1140.0" spacing="0" styleClass="card item-details-card">
            <children>
                <VBox spacing="6.0" styleClass="item-details-header">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Label fx:id="lblItemName" maxWidth="760.0" styleClass="label-header" text="Tên sản phẩm" wrapText="true" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblCategory" alignment="CENTER" minWidth="96.0" styleClass="details-category-chip" text="Item" />
                            </children>
                        </HBox>
                        <Label fx:id="lblExtraInfo" styleClass="details-muted-text" text="Thông tin thêm sẽ hiện ở đây" wrapText="true" />
                    </children>
                </VBox>

                <Separator />

                <ScrollPane fx:id="detailsScrollPane" fitToWidth="true" styleClass="auction-scroll-pane" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="22.0" styleClass="item-details-content">
                            <children>
                                <GridPane hgap="22.0" vgap="22.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="37.0" />
                                        <ColumnConstraints percentWidth="63.0" />
                                    </columnConstraints>
                                    <children>
                                        <VBox spacing="14.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                            <children>
                                                <StackPane styleClass="details-image-shell">
                                                    <children>
                                                        <ImageView fx:id="itemImageView" fitHeight="292.0" fitWidth="360.0" pickOnBounds="true" preserveRatio="true" />
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </VBox>

                                        <VBox spacing="14.0" styleClass="details-panel" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                            <children>
                                                <Label styleClass="details-section-title" text="Mô tả sản phẩm" />
                                                <TextArea fx:id="txtDescription" editable="false" prefHeight="191.0" prefWidth="350.0" styleClass="text-area details-description" wrapText="true" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="14.0" styleClass="details-panel chart-panel" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="details-section-title" text="↗ Diễn biến giá trực tuyến" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="lblHighestBidder" styleClass="details-muted-text" text="Chưa có ai dẫn đầu" />
                                                    </children>
                                                </HBox>

                                                <LineChart fx:id="bidChart" animated="false" createSymbols="true" legendVisible="false" prefHeight="270.0" styleClass="bid-chart">
                                                    <xAxis>
                                                        <NumberAxis fx:id="bidXAxis" forceZeroInRange="false" minorTickVisible="false" tickLabelsVisible="false" tickMarkVisible="false" />
                                                    </xAxis>
                                                    <yAxis>
                                                        <NumberAxis fx:id="bidYAxis" forceZeroInRange="false" minorTickVisible="false" />
                                                    </yAxis>
                                                </LineChart>

                                                <GridPane hgap="12.0" styleClass="bid-stat-grid">
                                                    <columnConstraints>
                                                        <ColumnConstraints percentWidth="23.0" />
                                                        <ColumnConstraints percentWidth="23.0" />
                                                        <ColumnConstraints percentWidth="14.0" />
                                                        <ColumnConstraints percentWidth="40.0" />
                                                    </columnConstraints>
                                                    <children>
                                                        <VBox maxWidth="Infinity" styleClass="bid-stat-card" GridPane.columnIndex="0">
                                                            <children>
                                                                <Label styleClass="bid-stat-label" text="Giá khởi điểm" wrapText="false" />
                                                                <Label fx:id="lblStartingPrice" styleClass="bid-stat-value" text="\$0.00" wrapText="false" />
                                                            </children>
                                                        </VBox>
                                                        <VBox maxWidth="Infinity" styleClass="bid-stat-card-current" GridPane.columnIndex="1">
                                                            <children>
                                                                <Label styleClass="bid-stat-label" text="Giá hiện tại" wrapText="false" />
                                                                <Label fx:id="lblCurrentPrice" styleClass="bid-stat-value" text="\$0.00" wrapText="false" />
                                                            </children>
                                                        </VBox>
                                                        <VBox maxWidth="Infinity" styleClass="bid-stat-card" GridPane.columnIndex="2">
                                                            <children>
                                                                <Label styleClass="bid-stat-label" text="Số lần đặt" wrapText="false" />
                                                                <Label fx:id="lblBidCount" styleClass="bid-stat-value" text="0" wrapText="false" />
                                                            </children>
                                                        </VBox>
                                                        <VBox maxWidth="Infinity" styleClass="bid-stat-card, bid-stat-card-end" GridPane.columnIndex="3">
                                                            <children>
                                                                <Label styleClass="bid-stat-label" text="Kết thúc lúc" wrapText="false" />
                                                                <Label fx:id="lblEndTime" maxWidth="Infinity" style="-fx-font-size: 24px; -fx-font-weight: 900;" styleClass="bid-stat-value, bid-stat-end-time" text="--/--/-- --:--" wrapText="false" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                       <rowConstraints>
                                          <RowConstraints />
                                       </rowConstraints>
                                                </GridPane>
                                            </children>
                                        </VBox>

                                        <VBox spacing="14.0" styleClass="details-panel bidding-panel" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                    <children>
                                                        <Label styleClass="details-section-title" text="Khu đấu giá" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label styleClass="details-muted-text" text="Bid gần nhất:" />
                                                        <Label fx:id="lblBidTime" styleClass="details-strong-text" text="-" />
                                                    </children>
                                                </HBox>

                                                <HBox spacing="12.0">
                                                    <children>
                                                        <Button fx:id="btnOpenBid" maxWidth="Infinity" onAction="#handleOpenBidDialog" prefHeight="48.0" styleClass="button-primary" text="ĐẶT GIÁ NGAY" HBox.hgrow="ALWAYS" />
                                                        <Button fx:id="btnPay" managed="false" maxWidth="Infinity" mnemonicParsing="false" onAction="#handlePay" prefHeight="48.0" style="-fx-background-color: #F59E0B;" styleClass="button-primary" text="THANH TOÁN NGAY" visible="false" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>

                                                <VBox fx:id="paneAutoBid" managed="false" spacing="12.0" styleClass="autobid-panel" visible="false">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                            <children>
                                                                <Label styleClass="details-section-title" text="Đấu giá tự động (Auto-bid)" />
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Label styleClass="details-muted-text" text="Hệ thống sẽ tự bid giúp bạn" />
                                                            </children>
                                                        </HBox>

                                                        <HBox spacing="12.0">
                                                            <children>
                                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label styleClass="form-label" text="Giá tối đa bạn sẵn sàng trả" />
                                                                        <TextField fx:id="txtAutoMaxBid" promptText="VD: 500.00" styleClass="text-field" />
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label styleClass="form-label" text="Mỗi bước tăng thêm" />
                                                                        <TextField fx:id="txtAutoIncrement" promptText="VD: 10.00" styleClass="text-field" />
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </HBox>

                                                        <HBox spacing="10.0">
                                                            <children>
                                                                <Button fx:id="btnSetAutoBid" maxWidth="Infinity" onAction="#handleSetAutoBid" prefHeight="40.0" style="-fx-background-color: #6366F1;" styleClass="button-primary" text="Kích hoạt Auto-Bid" HBox.hgrow="ALWAYS" />
                                                                <Button fx:id="btnCancelAutoBid" managed="false" onAction="#handleCancelAutoBid" prefHeight="40.0" styleClass="button-danger" text="Hủy Auto-Bid" visible="false" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                    <rowConstraints>
                                        <RowConstraints />
                                        <RowConstraints />
                                    </rowConstraints>
                                </GridPane>

                                <VBox spacing="12.0" styleClass="details-panel history-panel">
                                    <children>
                                        <Label styleClass="details-section-title" text="Lịch sử đấu giá" />
                                        <TableView fx:id="bidHistoryTable" prefHeight="220.0">
                                            <columns>
                                                <TableColumn fx:id="colBidder" prefWidth="250.0" text="Người đặt giá" />
                                                <TableColumn fx:id="colAmount" prefWidth="180.0" text="Số tiền" />
                                                <TableColumn fx:id="colTimestamp" prefWidth="260.0" text="Thời gian thực" />
                                                <TableColumn fx:id="colBidType" prefWidth="250.0" text="Kiểu đặt giá" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <Separator />

                <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="item-details-footer">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="40.0" prefWidth="100.0" styleClass="button-secondary" text="Đóng" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="10.0">
                            <children>
                                <Button fx:id="btnEdit" managed="false" mnemonicParsing="false" onAction="#handleEdit" prefHeight="40.0" styleClass="button-secondary" text="Sửa" visible="false" />
                                <Button fx:id="btnCancel" managed="false" mnemonicParsing="false" onAction="#handleCancelAuction" prefHeight="40.0" styleClass="button-danger" text="Hủy phiên" visible="false" />
                                <Button fx:id="btnDelete" managed="false" mnemonicParsing="false" onAction="#handleOpenDelete" prefHeight="40.0" styleClass="button-danger-confirm" text="Xóa" visible="false" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
