<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox fx:id="viewUsers" spacing="16.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminUsersController">
   <padding><Insets top="10.0" /></padding>

   <!-- USER STAT CARDS -->
   <HBox spacing="15.0">
      <children>
         <VBox prefHeight="80.0" styleClass="admin-stat-card, stat-card-blue" HBox.hgrow="ALWAYS">
            <children>
               <Label styleClass="admin-stat-label" text="TỔNG NGƯỜI DÙNG" />
               <HBox alignment="CENTER_LEFT" spacing="8.0" VBox.vgrow="ALWAYS">
                  <children>
                     <Label fx:id="labelTotalUsers" styleClass="admin-stat-value" text="--" />
                     <Label styleClass="admin-stat-unit" text="tài khoản" />
                  </children>
               </HBox>
            </children>
         </VBox>
         <VBox prefHeight="80.0" styleClass="admin-stat-card, stat-card-green" HBox.hgrow="ALWAYS">
            <children>
               <Label styleClass="admin-stat-label" text="NGƯỜI MUA (BIDDER)" />
               <HBox alignment="CENTER_LEFT" spacing="8.0" VBox.vgrow="ALWAYS">
                  <children>
                     <Label fx:id="labelTotalBidders" styleClass="admin-stat-value" text="--" />
                     <Label styleClass="admin-stat-unit" text="tài khoản" />
                  </children>
               </HBox>
            </children>
         </VBox>
         <VBox prefHeight="80.0" styleClass="admin-stat-card, stat-card-purple" HBox.hgrow="ALWAYS">
            <children>
               <Label styleClass="admin-stat-label" text="NGƯỜI BÁN (SELLER)" />
               <HBox alignment="CENTER_LEFT" spacing="8.0" VBox.vgrow="ALWAYS">
                  <children>
                     <Label fx:id="labelTotalSellers" styleClass="admin-stat-value" text="--" />
                     <Label styleClass="admin-stat-unit" text="tài khoản" />
                  </children>
               </HBox>
            </children>
         </VBox>
      </children>
   </HBox>

   <!-- SEARCH & ACTIONS BAR -->
   <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="admin-table-actions">
      <children>
         <HBox alignment="CENTER_LEFT" maxWidth="350.0" styleClass="search-box" HBox.hgrow="ALWAYS">
            <children>
               <Label style="-fx-text-fill: #94A3B8; -fx-padding: 0 0 0 12;" text="🔍" />
               <TextField fx:id="txtUserSearch" promptText="Tìm kiếm username, email..." styleClass="search-field" HBox.hgrow="ALWAYS" />
            </children>
         </HBox>
         <Region HBox.hgrow="ALWAYS" />
         <Button onAction="#handleRefresh" styleClass="button-secondary" text="↻ Làm mới bảng" />
      </children>
   </HBox>

   <!-- DATA TABLE -->
   <StackPane VBox.vgrow="ALWAYS">
      <children>
         <VBox styleClass="card, admin-table-container">
            <children>
               <TableView fx:id="userTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                  <columns>
                     <TableColumn fx:id="colUserId" prefWidth="100" text="Mã người dùng" />
                     <TableColumn fx:id="colUsername" prefWidth="160" text="Tên người dùng" />
                     <TableColumn fx:id="colEmail" prefWidth="240" text="Địa chỉ Email" />
                     <TableColumn fx:id="colRole" prefWidth="120" style="-fx-alignment: CENTER;" text="Vai trò" />
                     <TableColumn fx:id="colStatus" prefWidth="300" minWidth="240" style="-fx-alignment: CENTER;" text="Trạng thái" />
                     <TableColumn fx:id="colBalance" prefWidth="150" style="-fx-alignment: CENTER_RIGHT;" text="Số dư khả dụng" />
                  </columns>
                  <columnResizePolicy>
                     <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                  </columnResizePolicy>
               </TableView>
            </children>
         </VBox>

         <!-- EMPTY STATE USERS -->
         <VBox fx:id="paneEmptyUsers" alignment="CENTER" managed="false" spacing="20.0" styleClass="empty-state-pane" visible="false">
            <children>
               <StackPane prefHeight="100.0">
                  <children>
                     <SVGPath content="M16 7C16 9.20914 14.2091 11 12 11C9.79086 11 8 9.20914 8 7C8 4.79086 9.79086 3 12 3C14.2091 3 16 4.79086 16 7ZM12 14C8.13401 14 5 17.134 5 21H19C19 17.134 15.866 14 12 14Z" fill="TRANSPARENT" scaleX="3.5" scaleY="3.5" stroke="#CBD5E1" strokeWidth="1.5" />
                  </children>
               </StackPane>
               <Label styleClass="empty-state-title" text="Không tìm thấy người dùng" />
               <Label styleClass="empty-state-subtitle" text="Vui lòng kiểm tra lại Username hoặc Email" />
            </children>
         </VBox>
      </children>
   </StackPane>
</VBox>
