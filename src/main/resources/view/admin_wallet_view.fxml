<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="viewDeposits" managed="false" spacing="16.0" visible="false" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminWalletController">
   <padding><Insets top="10.0" /></padding>

   <!-- STAT + ACTIONS BAR -->
   <HBox spacing="15.0">
      <VBox prefHeight="80.0" styleClass="admin-stat-card, stat-card-blue" HBox.hgrow="ALWAYS">
         <Label styleClass="admin-stat-label" text="ĐANG CHỜ DUYỆT" />
         <HBox alignment="CENTER_LEFT" spacing="8.0" VBox.vgrow="ALWAYS">
            <Label fx:id="lblDepositCount" styleClass="admin-stat-value" text="--" />
            <Label styleClass="admin-stat-unit" text="yêu cầu" />
         </HBox>
      </VBox>
      <VBox prefHeight="80.0" styleClass="admin-stat-card"
            style="-fx-background-color: #f0fdf4; -fx-border-color: #bbf7d0;"
            HBox.hgrow="ALWAYS">
         <Label styleClass="admin-stat-label" text="NGÂN HÀNG NHẬN" />
         <VBox VBox.vgrow="ALWAYS" spacing="2.0">
            <Label text="BIDV — 4411622942"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #166534;"/>
            <Label text="Nguyễn Trung Hiếu"
                   style="-fx-font-size: 12px; -fx-text-fill: #4ade80;"/>
         </VBox>
      </VBox>
      <VBox alignment="BOTTOM_RIGHT" HBox.hgrow="NEVER">
         <Button onAction="#handleRefreshDeposits" prefHeight="42.0"
                 styleClass="button-secondary" text="↻ Làm mới" />
      </VBox>
   </HBox>

   <!-- DEPOSIT TABLE -->
   <StackPane VBox.vgrow="ALWAYS">
      <children>
         <VBox styleClass="card, admin-table-container">
            <children>
               <TableView fx:id="depositTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                  <columns>
                     <TableColumn fx:id="colDepositRefCode" prefWidth="180" text="Mã giao dịch" />
                     <TableColumn fx:id="colDepositUsername" prefWidth="150" text="Username" />
                     <TableColumn fx:id="colDepositAmount" prefWidth="130" style="-fx-alignment: CENTER_RIGHT;" text="Số tiền" />
                     <TableColumn fx:id="colDepositTime" prefWidth="140" text="Thời gian gửi" />
                     <TableColumn fx:id="colDepositAction" prefWidth="200" style="-fx-alignment: CENTER;" styleClass="centered-column" text="Hành động" />                                 </columns>
                  <columnResizePolicy>
                     <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                  </columnResizePolicy>
               </TableView>
            </children>
         </VBox>

         <!-- EMPTY STATE -->
         <VBox fx:id="paneEmptyDeposits" alignment="CENTER" managed="false" spacing="20.0" styleClass="empty-state-pane" visible="false">
            <Label styleClass="empty-state-title" text="Không có yêu cầu nạp tiền nào" />
            <Label styleClass="empty-state-subtitle" text="Khi người dùng gửi yêu cầu, chúng sẽ hiện ở đây" />
         </VBox>
      </children>
   </StackPane>
</VBox>
