<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="titleLabel" prefHeight="18.0" prefWidth="343.0" text="Online Auction Bidding System">
               <font>
                  <Font size="25.0" />
               </font>
            </Label>
            <TextField fx:id="textSearch" promptText="Search" />
            <Button mnemonicParsing="false" onAction="#handleLogout" text="Log out" textFill="RED" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <TableView fx:id="auctionTable" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colId" prefWidth="75.0" text="Id" />
          <TableColumn fx:id="colItemName" prefWidth="75.0" text="Name" />
            <TableColumn fx:id="colCurrentPrice" prefWidth="75.0" text="Price" />
            <TableColumn fx:id="colStatus" prefWidth="75.0" text="Status" />
        </columns>
      </TableView>
   </center>
   <right>
      <VBox prefHeight="300.0" prefWidth="143.0" spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="bidButton" mnemonicParsing="false" onAction="#handleBid" text="Bid" />
            <Button fx:id="detailsButton" mnemonicParsing="false" text="View details" />
            <Button fx:id="createSessionButton" mnemonicParsing="false" onAction="#handleCreateNewSession" text="Create new session" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </right>
</BorderPane>
