<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="740.0" prefWidth="1200.0" styleClass="dashboard-root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">

   <!-- ================= SIDEBAR ================= -->
   <left>
      <VBox alignment="TOP_CENTER" prefWidth="240.0" spacing="6.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="14.0" right="14.0" top="24.0" />
         </padding>
         <children>
            <!-- LOGO -->
            <ImageView fitHeight="110.0" fitWidth="110.0" pickOnBounds="true" preserveRatio="true" styleClass="sidebar-logo">
               <image>
                  <Image url="@../Images/bid-hub-logo.png" />
               </image>
            </ImageView>
            <Label styleClass="sidebar-brand" text="BidHub" />
            <Label styleClass="sidebar-brand-sub" text="Auction System" />

            <Region prefHeight="24.0" />

            <Label styleClass="sidebar-section" text="MENU" />

            <Button maxWidth="Infinity" mnemonicParsing="false" styleClass="sidebar-item, sidebar-item-active" text="⚖    Dashboard" />

            <Region VBox.vgrow="ALWAYS" />

            <Label fx:id="sidebarUserLabel" styleClass="sidebar-user" text="—" wrapText="true" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-logout" text="⏻    Đăng xuất" />
         </children>
      </VBox>
   </left>

   <!-- ================= MAIN CONTENT ================= -->
   <center>
      <VBox spacing="16.0" styleClass="main-content" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="22.0" left="26.0" right="26.0" top="22.0" />
         </padding>
         <children>

            <!-- TOP BAR: Title + Balance + Top-up -->
            <HBox alignment="CENTER_LEFT" spacing="14.0">
               <children>
                  <VBox spacing="2.0">
                     <Label fx:id="titleLabel" styleClass="page-title" text="Live Auctions" />
                     <Label styleClass="page-subtitle" text="Khám phá và đặt giá cho các phiên đang diễn ra" />
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />

                  <HBox alignment="CENTER" spacing="8.0" styleClass="balance-pill-light">
                     <Label styleClass="balance-icon" text="💰" />
                     <Label styleClass="balance-label-light" text="Số dư" />
                     <Label fx:id="lblBalance" styleClass="balance-value-light" text="\$0.00" />
                  </HBox>

                  <Button fx:id="btnTopUp" mnemonicParsing="false" onAction="#handleTopUp" prefHeight="40.0" prefWidth="140.0" styleClass="button-primary" text="+ Nạp tiền" />
               </children>
            </HBox>

            <!-- TOOLBAR -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="card toolbar-card">
               <padding>
                  <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
               </padding>
               <children>
                  <Button fx:id="bidButton" mnemonicParsing="false" onAction="#handleBid" prefHeight="38.0" prefWidth="120.0" styleClass="button-primary" text="Place Bid" />
                  <Button fx:id="createSessionButton" mnemonicParsing="false" onAction="#handleCreateNewSession" prefHeight="38.0" prefWidth="170.0" styleClass="button-primary" text="+ Create Session" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label styleClass="filter-label" text="Filter:" />
                  <ComboBox fx:id="comboFilter" prefHeight="38.0" prefWidth="160.0" promptText="All Categories" />
                  <TextField fx:id="textSearch" prefHeight="38.0" prefWidth="220.0" promptText="🔍  Search items..." />
               </children>
            </HBox>

            <!-- TABLE -->
            <StackPane styleClass="card table-card" VBox.vgrow="ALWAYS">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
               <children>
                  <TableView fx:id="auctionTable">
                     <columns>
                        <TableColumn fx:id="colId" prefWidth="100.0" text="ID" />
                        <TableColumn fx:id="colItemName" prefWidth="250.0" text="Item Name" />
                        <TableColumn fx:id="colCurrentPrice" prefWidth="120.0" text="Current Price ($)" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
                        <TableColumn fx:id="colCategory" prefWidth="150.0" text="Category" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </StackPane>

         </children>
      </VBox>
   </center>
</BorderPane>
