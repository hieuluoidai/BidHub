<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.ComboBox?>
<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">

   <top>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>

            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Label fx:id="titleLabel" text="Online Auction Bidding System">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />

                  <Label text="Filter:" />
                  <ComboBox fx:id="comboFilter" prefWidth="120.0" promptText="All Categories" />

                  <TextField fx:id="textSearch" prefWidth="180.0" promptText="Search items..." />
                  <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-font-weight: bold;" text="Log out" textFill="RED" />
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Button fx:id="bidButton" mnemonicParsing="false" onAction="#handleBid" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Place Bid" />
                  <Button fx:id="createSessionButton" mnemonicParsing="false" onAction="#handleCreateNewSession" prefHeight="30.0" prefWidth="150.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" text="+ Create Session" />
               </children>
            </HBox>

         </children>
      </VBox>
   </top>

   <center>
      <TableView fx:id="auctionTable" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colId" prefWidth="100.0" text="ID" />
            <TableColumn fx:id="colItemName" prefWidth="250.0" text="Item Name" />
            <TableColumn fx:id="colCurrentPrice" prefWidth="120.0" text="Current Price ($)" />
            <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
            <TableColumn fx:id="colCategory" prefWidth="150.0" text="Category" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <BorderPane.margin>
            <Insets bottom="15.0" left="15.0" right="15.0" top="5.0" />
         </BorderPane.margin>
      </TableView>
   </center>

</BorderPane>