<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="380.0" prefWidth="400.0" spacing="20.0" styleClass="card" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BidController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
   <children>

      <VBox spacing="5.0">
         <children>
            <Label styleClass="label-header" text="Place Your Bid">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Label styleClass="decrement-button" text="Enter an amount higher than the current price" textFill="#666666" />
         </children>
         <VBox.margin>
            <Insets bottom="5.0" />
         </VBox.margin>
      </VBox>

      <VBox spacing="8.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 5; -fx-padding: 15; -fx-border-color: #e0e0e0; -fx-border-radius: 5;">
         <children>
            <Label fx:id="labelItemName" text="Item Name" wrapText="true">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
            <Label fx:id="labelCurrentPrice" styleClass="label-price" text="Current Price: $0.00" textFill="#e65100">
               <font>
                  <Font name="System Bold" size="15.0" />
               </font>
            </Label>
         </children>
      </VBox>

      <VBox spacing="5.0">
         <Label text="Your Bid Amount ($)">
            <font><Font name="System Bold" size="12.0" /></font>
         </Label>
         <TextField fx:id="textBidAmount" prefHeight="45.0" promptText="e.g. 250.0" style="-fx-background-radius: 5; -fx-font-size: 15px;" />
      </VBox>

      <Label fx:id="labelError" textFill="#ff3333" wrapText="true">
         <font>
            <Font size="13.0" />
         </font>
      </Label>

      <HBox alignment="CENTER_RIGHT" spacing="15.0">
         <children>
            <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#handleCancel" styleClass="button-secondary" text="Cancel" />
            <Button fx:id="confirmButton" defaultButton="true" mnemonicParsing="false" onAction="#handleConfirm" prefHeight="40.0" prefWidth="130.0" styleClass="button-primary" text="Confirm Bid" />
         </children>
         <VBox.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </VBox.margin>
      </HBox>

   </children>
</VBox>
