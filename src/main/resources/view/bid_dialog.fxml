<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>

<VBox prefWidth="450.0" spacing="20.0" styleClass="card" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BidController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
   <children>
      <!-- Header -->
      <VBox spacing="5.0">
         <children>
            <Label styleClass="label-header" text="ĐẶT GIÁ CỦA BẠN">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Label style="-fx-text-fill: #64748B;" text="Nhập số tiền cao hơn giá hiện tại để tham gia" />
         </children>
      </VBox>

      <!-- Item and Price Info Card -->
      <VBox spacing="12.0" style="-fx-background-color: #F8FAFC; -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 12;">
         <children>
            <Label fx:id="labelItemName" style="-fx-font-weight: 800; -fx-font-size: 16; -fx-text-fill: #1E293B;" text="Tên sản phẩm" wrapText="true" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label styleClass="form-label" text="Giá hiện tại:" />
                  <Label fx:id="labelCurrentPrice" style="-fx-text-fill: #10B981; -fx-font-weight: 900; -fx-font-size: 18;" text="\$0.00" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label styleClass="form-label" text="Số dư khả dụng:" />
                  <Label fx:id="labelUserBalance" style="-fx-text-fill: #3B82F6; -fx-font-weight: 700;" text="\$0.00" />
               </children>
            </HBox>
         </children>
      </VBox>

      <!-- Input Section -->
      <VBox spacing="10.0">
         <children>
            <Label styleClass="form-label" text="Số tiền bạn muốn đặt ($)" />
            <TextField fx:id="textBidAmount" prefHeight="50.0" promptText="VD: 250.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 10;" />
            
            <!-- Quick Bid Buttons -->
            <HBox spacing="10.0">
               <children>
                  <Button onAction="#addBid10" styleClass="button-secondary" text="+10" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                  <Button onAction="#addBid50" styleClass="button-secondary" text="+50" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                  <Button onAction="#addBid100" styleClass="button-secondary" text="+100" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
               </children>
            </HBox>
         </children>
      </VBox>

      <Label fx:id="labelError" style="-fx-text-fill: #EF4444; -fx-font-size: 13; -fx-font-weight: bold;" wrapText="true" />

      <!-- Action Buttons -->
      <HBox alignment="CENTER_RIGHT" spacing="15.0">
         <children>
            <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#handleCancel" prefHeight="45.0" prefWidth="100.0" styleClass="button-secondary" text="Hủy" />
            <Button fx:id="confirmButton" defaultButton="true" mnemonicParsing="false" onAction="#handleConfirm" prefHeight="45.0" styleClass="button-primary" text="XÁC NHẬN ĐẶT GIÁ" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
         </children>
      </HBox>
   </children>
</VBox>
