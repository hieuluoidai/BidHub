<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="400.0" spacing="20.0" styleClass="card" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ChangePasswordController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
   <children>
      <VBox spacing="5.0">
         <children>
            <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Đổi mật khẩu" />
            <Label style="-fx-text-fill: #64748B; -fx-font-size: 13;" text="Vui lòng nhập mật khẩu cũ và mật khẩu mới" />
         </children>
      </VBox>
      
      <VBox spacing="15.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label style="-fx-font-weight: bold;" text="Mật khẩu cũ" />
                  <PasswordField fx:id="txtOldPassword" styleClass="text-field" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label style="-fx-font-weight: bold;" text="Mật khẩu mới" />
                  <PasswordField fx:id="txtNewPassword" styleClass="text-field" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label style="-fx-font-weight: bold;" text="Xác nhận mật khẩu mới" />
                  <PasswordField fx:id="txtConfirmPassword" styleClass="text-field" />
               </children>
            </VBox>
         </children>
      </VBox>
      
      <HBox alignment="CENTER_RIGHT" spacing="12.0">
         <children>
            <Button onAction="#handleCancel" styleClass="button-secondary" text="Hủy" />
            <Button onAction="#handleChangePassword" styleClass="button-primary" text="Đổi mật khẩu" />
         </children>
      </HBox>
   </children>
</VBox>
