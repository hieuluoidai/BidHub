<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="760.0" prefWidth="1280.0"
            styleClass="dashboard-root"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.AdminController">

   <!-- ================= SIDEBAR ================= -->
   <left>
      <VBox alignment="TOP_CENTER" prefWidth="240.0" spacing="6.0" styleClass="sidebar">
         <padding><Insets bottom="20.0" left="14.0" right="14.0" top="24.0"/></padding>

         <ImageView fitHeight="110.0" fitWidth="110.0" pickOnBounds="true" preserveRatio="true" styleClass="sidebar-logo">
            <image><Image url="@../Images/bid-hub-logo.png"/></image>
         </ImageView>
         <Label styleClass="sidebar-brand" text="BidHub"/>
         <Label styleClass="sidebar-brand-sub" text="Admin Console"/>

         <Region prefHeight="24.0"/>

         <Label styleClass="sidebar-section" text="MENU"/>

         <Button fx:id="navAuctionsBtn" maxWidth="Infinity" mnemonicParsing="false"
                 onAction="#handleNavAuctions"
                 styleClass="sidebar-item, sidebar-item-active"
                 text="⚖    Phiên đấu giá"/>

         <Button fx:id="navUsersBtn" maxWidth="Infinity" mnemonicParsing="false"
                 onAction="#handleNavUsers"
                 styleClass="sidebar-item"
                 text="👥    Quản lý người dùng"/>

         <Region VBox.vgrow="ALWAYS"/>

         <Label fx:id="labelAdminName" styleClass="sidebar-user" text="—" wrapText="true"/>
         <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogout"
                 styleClass="sidebar-logout" text="⏻    Đăng xuất"/>
      </VBox>
   </left>

   <!-- ================= MAIN CONTENT ================= -->
   <center>
      <VBox spacing="16.0" styleClass="main-content">
         <padding><Insets bottom="22.0" left="26.0" right="26.0" top="22.0"/></padding>

         <!-- TOP BAR -->
         <HBox alignment="CENTER_LEFT" spacing="14.0">
            <VBox spacing="2.0">
               <Label fx:id="pageTitleLabel" styleClass="page-title" text="Phiên đấu giá"/>
               <Label fx:id="pageSubtitleLabel" styleClass="page-subtitle" text="Tổng quan toàn bộ phiên đấu giá trong hệ thống"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button styleClass="button-primary" text="View Details"   onAction="#handleViewDetails"  prefHeight="38.0" prefWidth="130.0"/>
            <Button styleClass="button-primary" text="+ Create Session" onAction="#handleCreateSession" prefHeight="38.0" prefWidth="160.0"/>
            <Button styleClass="button-primary" text="Refresh"        onAction="#handleRefresh"       prefHeight="38.0" prefWidth="100.0"/>
         </HBox>

         <!-- TAB CONTENT (tab header bị ẩn — điều hướng qua sidebar) -->
         <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" styleClass="hidden-tabs" VBox.vgrow="ALWAYS">

            <Tab text="Phiên đấu giá">
               <VBox spacing="12.0">
                  <padding><Insets top="6.0"/></padding>

                  <HBox spacing="12.0">
                     <Label fx:id="labelTotalAuctions" text="Tổng phiên: --" styleClass="stat-chip stat-blue"/>
                     <Label fx:id="labelRunningAuctions" text="Đang chạy: --" styleClass="stat-chip stat-green"/>
                     <Label fx:id="labelFinishedAuctions" text="Đã kết thúc: --" styleClass="stat-chip stat-orange"/>
                  </HBox>

                  <StackPane styleClass="card table-card" VBox.vgrow="ALWAYS">
                     <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>
                     <TableView fx:id="auctionTable">
                        <columns>
                           <TableColumn fx:id="colAucId"     text="ID"           prefWidth="130"/>
                           <TableColumn fx:id="colAucItem"   text="Sản phẩm"     prefWidth="220"/>
                           <TableColumn fx:id="colAucStatus" text="Trạng thái"   prefWidth="110"/>
                           <TableColumn fx:id="colAucPrice"  text="Giá cao nhất" prefWidth="130"/>
                           <TableColumn fx:id="colAucWinner" text="Người thắng"  prefWidth="150"/>
                        </columns>
                        <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                     </TableView>
                  </StackPane>
               </VBox>
            </Tab>

            <Tab text="Quản lý người dùng">
               <VBox spacing="12.0">
                  <padding><Insets top="6.0"/></padding>

                  <HBox spacing="12.0">
                     <Label fx:id="labelTotalUsers"   text="Tổng users: --" styleClass="stat-chip stat-blue"/>
                     <Label fx:id="labelTotalBidders" text="Bidders: --"    styleClass="stat-chip stat-green"/>
                     <Label fx:id="labelTotalSellers" text="Sellers: --"    styleClass="stat-chip stat-purple"/>
                  </HBox>

                  <StackPane styleClass="card table-card" VBox.vgrow="ALWAYS">
                     <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>
                     <TableView fx:id="userTable">
                        <columns>
                           <TableColumn fx:id="colUserId"   text="User ID"  prefWidth="150"/>
                           <TableColumn fx:id="colUsername" text="Username" prefWidth="180"/>
                           <TableColumn fx:id="colEmail"    text="Email"    prefWidth="250"/>
                           <TableColumn fx:id="colRole"     text="Role"     prefWidth="120"/>
                           <TableColumn fx:id="colBalance"  text="Số dư"    prefWidth="140"/>
                        </columns>
                        <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                     </TableView>
                  </StackPane>
               </VBox>
            </Tab>
         </TabPane>
      </VBox>
   </center>
</BorderPane>
