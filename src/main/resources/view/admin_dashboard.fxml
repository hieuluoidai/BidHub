<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="950.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.AdminController">

   <!-- ===== HEADER ===== -->
   <top>
      <VBox styleClass="card" spacing="8.0">
         <padding><Insets bottom="15.0" left="25.0" right="25.0" top="15.0"/></padding>
         <HBox alignment="CENTER_LEFT" spacing="12.0">
   			<VBox spacing="2.0">
      			<Label text="Admin Dashboard" styleClass="label-header">
         			<font><Font name="System Bold" size="22.0"/></font>
     			</Label>
      			<Label fx:id="labelAdminName" textFill="#64748B"/>
  			</VBox>
  			<Region HBox.hgrow="ALWAYS"/>
   			<Button styleClass="button-primary" text="View Details" onAction="#handleViewDetails" prefHeight="36.0" prefWidth="120.0"/>
   			<Button styleClass="button-primary" text="+ Create Session" onAction="#handleCreateSession" prefHeight="36.0" prefWidth="150.0"/>
  			<Button styleClass="button-primary" text="Refresh" onAction="#handleRefresh" prefHeight="36.0" prefWidth="100.0"/>
   			<Button styleClass="button-danger"  text="Log out" onAction="#handleLogout" prefHeight="36.0" prefWidth="90.0"/>
		 </HBox>
      </VBox>
   </top>

   <!-- ===== NỘI DUNG ===== -->
   <center>
      <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" style="-fx-font-size: 13px;">
         <padding><Insets bottom="15.0" left="15.0" right="15.0" top="10.0"/></padding>

         <!-- Tab 1: Tất cả phiên đấu giá -->
         <Tab text="Tất cả phiên đấu giá">
            <VBox spacing="10.0">
               <padding><Insets top="12.0"/></padding>

               <HBox spacing="12.0">
                  <Label fx:id="labelTotalAuctions" text="Tổng phiên: --"
                         style="-fx-background-color:#EFF6FF; -fx-text-fill:#1D4ED8;
                                -fx-padding: 6 14 6 14; -fx-background-radius:6;
                                -fx-font-weight:bold; -fx-font-size:12px;"/>
                  <Label fx:id="labelRunningAuctions" text="Đang chạy: --"
                         style="-fx-background-color:#F0FDF4; -fx-text-fill:#15803D;
                                -fx-padding: 6 14 6 14; -fx-background-radius:6;
                                -fx-font-weight:bold; -fx-font-size:12px;"/>
                  <Label fx:id="labelFinishedAuctions" text="Đã kết thúc: --"
                         style="-fx-background-color:#FFF7ED; -fx-text-fill:#C2410C;
                                -fx-padding: 6 14 6 14; -fx-background-radius:6;
                                -fx-font-weight:bold; -fx-font-size:12px;"/>
               </HBox>

               <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS">
                  <columns>
                     <TableColumn fx:id="colAucId"     text="ID"           prefWidth="130"/>
                     <TableColumn fx:id="colAucItem"   text="Sản phẩm"     prefWidth="220"/>
                     <TableColumn fx:id="colAucStatus" text="Trạng thái"   prefWidth="110"/>
                     <TableColumn fx:id="colAucPrice"  text="Giá cao nhất" prefWidth="130"/>
                     <TableColumn fx:id="colAucWinner" text="Người thắng"  prefWidth="150"/>
                  </columns>
                  <columnResizePolicy>
                     <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                  </columnResizePolicy>
               </TableView>
            </VBox>
         </Tab>

         <!-- Tab 2: Quản lý người dùng -->
         <Tab text="Quản lý người dùng">
            <VBox spacing="10.0">
               <padding><Insets top="12.0"/></padding>

               <HBox spacing="12.0">
                  <Label fx:id="labelTotalUsers" text="Tổng users: --"
                         style="-fx-background-color:#EFF6FF; -fx-text-fill:#1D4ED8;
                                -fx-padding: 6 14 6 14; -fx-background-radius:6;
                                -fx-font-weight:bold; -fx-font-size:12px;"/>
                  <Label fx:id="labelTotalBidders" text="Bidders: --"
                         style="-fx-background-color:#F0FDF4; -fx-text-fill:#15803D;
                                -fx-padding: 6 14 6 14; -fx-background-radius:6;
                                -fx-font-weight:bold; -fx-font-size:12px;"/>
                  <Label fx:id="labelTotalSellers" text="Sellers: --"
                         style="-fx-background-color:#FDF4FF; -fx-text-fill:#7E22CE;
                                -fx-padding: 6 14 6 14; -fx-background-radius:6;
                                -fx-font-weight:bold; -fx-font-size:12px;"/>
               </HBox>

               <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                  <columns>
                     <TableColumn fx:id="colUserId"   text="User ID"  prefWidth="150"/>
                     <TableColumn fx:id="colUsername" text="Username" prefWidth="180"/>
                     <TableColumn fx:id="colEmail"    text="Email"    prefWidth="250"/>
                     <TableColumn fx:id="colRole"     text="Role"     prefWidth="120"/>
                  </columns>
                  <columnResizePolicy>
                     <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                  </columnResizePolicy>
               </TableView>
            </VBox>
         </Tab>

      </TabPane>
   </center>

</BorderPane>
