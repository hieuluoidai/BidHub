<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.CreateSessionController">
    <children>
        <VBox maxHeight="820.0" maxWidth="500.0" prefHeight="780.0" prefWidth="450.0" spacing="15.0" styleClass="card">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label-header" text="Create Session">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                        <Label text="Fill in the details to start a new auction" textFill="#666666" />
                    </children>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </VBox>

                <VBox spacing="5.0">
                    <Label fx:id="labelItemName" text="Item Name">
                        <font>
                            <Font name="System Bold" size="12.0" />
                        </font>
                    </Label>
                    <TextField fx:id="textItemName" prefHeight="40.0" promptText="Enter item name..." style="-fx-background-radius: 5;" />
                </VBox>

                <HBox spacing="15.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label fx:id="labelStartingPrice" text="Starting Price (\$)">
                                <font>
                                    <Font name="System Bold" size="12.0" />
                                </font>
                            </Label>
                            <TextField fx:id="textStartingPrice" prefHeight="40.0" promptText="e.g. 150.0" style="-fx-background-radius: 5;" VBox.vgrow="ALWAYS" />
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label fx:id="labelItemType" text="Item Type">
                                <font>
                                    <Font name="System Bold" size="12.0" />
                                </font>
                            </Label>
                            <ComboBox fx:id="cbItemType" maxWidth="1.7976931348623157E308" prefHeight="40.0" promptText="Select Type" style="-fx-background-radius: 5;" VBox.vgrow="ALWAYS" />
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="5.0">
                    <Label fx:id="labelExtraInfo" text="Brand / Author">
                        <font>
                            <Font name="System Bold" size="12.0" />
                        </font>
                    </Label>
                    <TextField fx:id="textExtraInfo" prefHeight="40.0" promptText="e.g. Apple, Leonardo da Vinci..." style="-fx-background-radius: 5;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label fx:id="labelDescription" text="Description">
                        <font>
                            <Font name="System Bold" size="12.0" />
                        </font>
                    </Label>
                    <TextField fx:id="textDescription" alignment="TOP_LEFT" prefHeight="80.0" promptText="Item description..." />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Ảnh sản phẩm (tùy chọn)">
                        <font>
                            <Font name="System Bold" size="12.0" />
                        </font>
                    </Label>
                    <HBox spacing="12.0" alignment="CENTER_LEFT">
                        <ImageView fx:id="imagePreview" fitHeight="80.0" fitWidth="80.0" preserveRatio="true" pickOnBounds="true" />
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <HBox spacing="8.0">
                                <Button fx:id="btnChooseImage" mnemonicParsing="false" onAction="#handleChooseImage" prefHeight="32.0" prefWidth="120.0" styleClass="button-secondary" text="Chọn ảnh..." />
                                <Button fx:id="btnRemoveImage" managed="false" mnemonicParsing="false" onAction="#handleRemoveImage" prefHeight="32.0" prefWidth="100.0" styleClass="button-danger" text="Bỏ chọn" visible="false" />
                            </HBox>
                            <Label fx:id="lblImageStatus" text="" wrapText="true" textFill="#64748b">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </Label>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Thời điểm kết thúc phiên đấu giá">
                        <font>
                            <Font name="System Bold" size="12.0" />
                        </font>
                    </Label>
                    <HBox spacing="10.0">
                        <children>
                            <DatePicker fx:id="datePickerEndDate" maxWidth="Infinity" prefHeight="40.0" prefWidth="211.0" promptText="Chọn ngày" HBox.hgrow="ALWAYS" />
                            <ComboBox fx:id="cbEndHour" prefHeight="46.0" prefWidth="101.0" promptText="Giờ" />
                            <ComboBox fx:id="cbEndMinute" prefHeight="46.0" prefWidth="102.0" promptText="Phút" />
                        </children>
                    </HBox>
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Bắt đầu sau (giây)">
                        <font>
                            <Font name="System Bold" size="12.0" />
                        </font>
                    </Label>
                    <TextField fx:id="textStartDelay" prefHeight="40.0"
                               promptText="VD: 15 (mặc định nếu để trống)"
                               style="-fx-background-radius: 5;" />
                    <Label text="Phiên sẽ chuyển từ OPEN → RUNNING sau số giây này. Min 1, Max 86400 (1 ngày)."
                           style="-fx-font-size: 11px; -fx-text-fill: #64748b;" wrapText="true" />
                </VBox>

                <Label fx:id="labelError" textFill="#ff3333" wrapText="true" />

                <Region VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button cancelButton="true" mnemonicParsing="false" onAction="#handleCancel" prefHeight="40.0" prefWidth="100.0" styleClass="button-secondary" text="Cancel" />
                        <Button defaultButton="true" mnemonicParsing="false" onAction="#handleSave" prefHeight="40.0" prefWidth="120.0" styleClass="button-primary" text="Save Session" />
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>

            </children>
        </VBox>
    </children>
</StackPane>
