<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="550.0" prefWidth="450.0" spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.CreateSessionController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
   <children>

      <VBox spacing="5.0">
         <children>
            <Label text="Create Session">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Label text="Fill in the details to start a new auction" textFill="#666666" />
         </children>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </VBox>

      <VBox spacing="5.0">
         <Label text="Item Name">
            <font><Font name="System Bold" size="12.0" /></font>
         </Label>
         <TextField fx:id="textItemName" prefHeight="40.0" promptText="Enter item name..." style="-fx-background-radius: 5;" />
      </VBox>

      <HBox spacing="15.0">
         <children>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label text="Starting Price ($)">
                  <font><Font name="System Bold" size="12.0" /></font>
               </Label>
               <TextField fx:id="textStartingPrice" prefHeight="40.0" promptText="e.g. 150.0" style="-fx-background-radius: 5;" />
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label text="Item Type">
                  <font><Font name="System Bold" size="12.0" /></font>
               </Label>
               <ComboBox fx:id="cbItemType" maxWidth="1.7976931348623157E308" prefHeight="40.0" promptText="Select Type" style="-fx-background-radius: 5;" />
            </VBox>
         </children>
      </HBox>

      <VBox spacing="5.0">
         <Label fx:id="labelExtraInfo" text="Brand / Author">
            <font><Font name="System Bold" size="12.0" /></font>
         </Label>
         <TextField fx:id="textExtraInfo" prefHeight="40.0" promptText="e.g. Apple, Leonardo da Vinci..." style="-fx-background-radius: 5;" />
      </VBox>

      <VBox spacing="5.0">
         <Label text="Description">
            <font><Font name="System Bold" size="12.0" /></font>
         </Label>
         <TextField fx:id="textDescription" alignment="TOP_LEFT" prefHeight="80.0" promptText="Item description..." style="-fx-background-radius: 5;" />
      </VBox>

      <Label fx:id="labelError" textFill="#ff3333" wrapText="true" />

      <Region VBox.vgrow="ALWAYS" />

      <HBox alignment="CENTER_RIGHT" spacing="15.0">
         <children>
            <Button cancelButton="true" mnemonicParsing="false" onAction="#handleCancel" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-cursor: hand;" text="Cancel" />
            <Button defaultButton="true" mnemonicParsing="false" onAction="#handleSave" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Save Session" />
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </HBox>

   </children>
</VBox>