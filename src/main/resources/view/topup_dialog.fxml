<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="380.0" prefWidth="430.0" spacing="18.0" styleClass="card"
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.TopUpController">
    <padding>
        <Insets top="35.0" right="35.0" bottom="30.0" left="35.0"/>
    </padding>

    <!-- Tiêu đề -->
    <VBox spacing="4.0">
        <Label styleClass="label-header" text="Nạp tiền vào tài khoản">
            <font><Font name="System Bold" size="22.0"/></font>
        </Label>
        <Label text="Tiền nạp sẽ vào ngay sau khi xử lý" textFill="#64748b">
            <font><Font size="13.0"/></font>
        </Label>
    </VBox>

    <!-- Box hiển thị số dư hiện tại -->
    <VBox spacing="4.0"
          style="-fx-background-color: #f0f9ff; -fx-background-radius: 8;
                 -fx-border-color: #bae6fd; -fx-border-radius: 8; -fx-padding: 14;">
        <Label text="Số dư hiện tại"
               style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;"/>
        <Label fx:id="lblCurrentBalance" text="\$0.00"
               style="-fx-font-size: 22px; -fx-text-fill: #0369a1; -fx-font-weight: 800;"/>
    </VBox>

    <!-- Số tiền cần nạp -->
    <VBox spacing="6.0">
        <Label text="Số tiền cần nạp (\$)"
               style="-fx-font-size: 12px; -fx-text-fill: #334155; -fx-font-weight: bold;"/>
        <TextField fx:id="textAmount" prefHeight="44.0"
                   promptText="VD: 5000"
                   style="-fx-background-radius: 8; -fx-font-size: 15px;"/>
    </VBox>

    <!-- Thông báo lỗi -->
    <Label fx:id="lblError" wrapText="true">
        <font><Font size="13.0"/></font>
    </Label>

    <!-- Loading indicator -->
    <HBox alignment="CENTER" spacing="10.0">
        <ProgressIndicator fx:id="progressIndicator" prefHeight="22.0" prefWidth="22.0" managed="false" visible="false"/>
        <Label text="Đang xử lý giao dịch..." textFill="#64748b" managed="false"/>
    </HBox>

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancel"
                prefHeight="42.0" prefWidth="90.0"
                styleClass="button-secondary" text="Hủy"/>
        <Button fx:id="btnTopUp" defaultButton="true" mnemonicParsing="false"
                onAction="#handleTopUp"
                prefHeight="42.0" prefWidth="140.0"
                styleClass="button-primary" text="NẠP NGAY"/>
    </HBox>
</VBox>
