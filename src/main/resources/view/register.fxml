<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="780.0" prefWidth="1100.0"
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.RegisterController">

    <VBox alignment="CENTER" spacing="24.0" styleClass="auth-brand-panel"
          HBox.hgrow="ALWAYS" minWidth="380.0" prefWidth="450.0">
        <padding>
            <Insets top="60.0" right="50.0" bottom="60.0" left="50.0"/>
        </padding>

        <ImageView fitHeight="120.0" fitWidth="120.0" preserveRatio="true">
            <image>
                <Image url="@../Images/bid-hub-logo.png"/>
            </image>
        </ImageView>

        <Label styleClass="brand-title" text="BidHub"/>
        <Label styleClass="brand-subtitle" text="Hệ thống đấu giá trực tuyến" wrapText="true"/>

        <Region prefHeight="20.0"/>

        <VBox spacing="18.0" maxWidth="320.0">
            <HBox spacing="14.0" alignment="CENTER_LEFT">
                <Label styleClass="brand-bullet-icon" text="✓"/>
                <Label styleClass="brand-bullet-text"
                       text="Đấu giá realtime với hàng nghìn người tham gia"
                       wrapText="true" HBox.hgrow="ALWAYS"/>
            </HBox>
            <HBox spacing="14.0" alignment="CENTER_LEFT">
                <Label styleClass="brand-bullet-icon" text="✓"/>
                <Label styleClass="brand-bullet-text"
                       text="Bảo mật thông tin với mã hóa BCrypt"
                       wrapText="true" HBox.hgrow="ALWAYS"/>
            </HBox>
            <HBox spacing="14.0" alignment="CENTER_LEFT">
                <Label styleClass="brand-bullet-icon" text="✓"/>
                <Label styleClass="brand-bullet-text"
                       text="Đăng ký miễn phí, sử dụng ngay lập tức"
                       wrapText="true" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </VBox>

    <StackPane HBox.hgrow="ALWAYS" style="-fx-background-color: white;">
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <StackPane>
                <padding>
                    <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
                </padding>

                <VBox alignment="TOP_CENTER" maxWidth="460.0" spacing="14.0">

                    <VBox spacing="6.0" alignment="TOP_LEFT" maxWidth="Infinity">
                        <Label styleClass="auth-title" text="Tạo tài khoản mới"/>
                        <Label styleClass="auth-subtitle"
                               text="Điền thông tin để bắt đầu hành trình của bạn"/>
                    </VBox>

                    <VBox spacing="4.0">
                        <Label styleClass="form-label" text="Họ và tên"/>
                        <TextField fx:id="fullNameField" styleClass="form-input"
                                   promptText="Ví dụ: Nguyễn Văn An"/>
                        <Label fx:id="hintFullName" styleClass="form-hint" wrapText="true"/>
                    </VBox>

                    <HBox spacing="14.0">
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="form-label" text="Ngày sinh"/>
                            <DatePicker fx:id="dobPicker" styleClass="form-input"
                                        maxWidth="Infinity" promptText="d/M/yyyy"/>
                            <Label fx:id="hintDob" styleClass="form-hint" wrapText="true"/>
                        </VBox>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="form-label" text="Số điện thoại"/>
                            <TextField fx:id="phoneField" styleClass="form-input"
                                       promptText="VD: 0912345678"/>
                            <Label fx:id="hintPhone" styleClass="form-hint" wrapText="true"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="4.0">
                        <Label styleClass="form-label" text="Email"/>
                        <TextField fx:id="emailField" styleClass="form-input"
                                   promptText="example@gmail.com"/>
                        <Label fx:id="hintEmail" styleClass="form-hint" wrapText="true"/>
                    </VBox>

                    <VBox spacing="4.0">
                        <Label styleClass="form-label" text="Tên đăng nhập"/>
                        <TextField fx:id="usernameField" styleClass="form-input"
                                   promptText="3–20 ký tự, gồm chữ, số, dấu gạch dưới"/>
                        <Label fx:id="hintUsername" styleClass="form-hint" wrapText="true"/>
                    </VBox>

                    <HBox spacing="14.0">
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="form-label" text="Mật khẩu"/>
                            <PasswordField fx:id="passwordField" styleClass="form-input"
                                           promptText="≥ 8 ký tự, có chữ thường + số"/>
                            <Label fx:id="hintPassword" styleClass="form-hint" wrapText="true"/>
                        </VBox>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="form-label" text="Xác nhận mật khẩu"/>
                            <PasswordField fx:id="confirmPasswordField" styleClass="form-input"
                                           promptText="Nhập lại mật khẩu"/>
                            <Label fx:id="hintConfirm" styleClass="form-hint" wrapText="true"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="4.0">
                        <Label styleClass="form-label" text="Vai trò"/>
                        <ChoiceBox fx:id="roleChoice" styleClass="form-input"
                                   maxWidth="Infinity"/>
                    </VBox>

                    <Label fx:id="messageLabel" styleClass="form-error" wrapText="true"/>

                    <Button defaultButton="true" mnemonicParsing="false"
                            onAction="#handleRegister"
                            maxWidth="Infinity"
                            styleClass="button-primary,button-large" text="ĐĂNG KÝ"/>

                    <HBox alignment="CENTER" spacing="2.0">
                        <Label styleClass="auth-helper-text" text="Đã có tài khoản? "/>
                        <Hyperlink onAction="#handleBackToLogin"
                                   styleClass="auth-link"
                                   text="Đăng nhập ngay"/>
                    </HBox>
                </VBox>
            </StackPane>
        </ScrollPane>
    </StackPane>
</HBox>
