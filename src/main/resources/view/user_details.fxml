<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.shape.Circle?>

<VBox prefWidth="480.0" spacing="16.0" styleClass="card" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.UserDetailsController">
   <fx:define>
       <Circle fx:id="avatarClip" radius="32" centerX="32" centerY="32" />
   </fx:define>
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>

   <HBox fx:id="profileHeader" alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10; -fx-background-radius: 12;">
      <StackPane fx:id="avatarContainer" onMouseClicked="#handleAvatarClick" prefWidth="64" prefHeight="64">
         <Label fx:id="lblAvatar" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold; -fx-min-width: 64px; -fx-min-height: 64px; -fx-max-width: 64px; -fx-max-height: 64px; -fx-background-radius: 50%; -fx-alignment: center;" text="?" />
         <ImageView fx:id="imgAvatar" fitWidth="64" fitHeight="64" visible="false" preserveRatio="false" />
         <StackPane fx:id="cameraOverlay" style="-fx-background-color: rgba(0,0,0,0.5); -fx-background-radius: 50%;" visible="false">
             <Label text="📷" style="-fx-text-fill: white; -fx-font-size: 24px;"/>
         </StackPane>
         <cursor>
             <javafx.scene.Cursor fx:constant="HAND"/>
         </cursor>
      </StackPane>

      <VBox spacing="3.0">
         <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label fx:id="lblUsername" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="username" />
            <Label fx:id="lblUserId" style="-fx-font-size: 14px; -fx-text-fill: #64748B;" text="(u-id)" />
         </HBox>
         <Label fx:id="lblRoleBadge" style="-fx-background-color: #EFF6FF; -fx-text-fill: #1D4ED8; -fx-padding: 3 10 3 10; -fx-background-radius: 4; -fx-font-weight: bold; -fx-font-size: 11px;" text="ROLE" />
      </VBox>
   </HBox>

   <VBox fx:id="paneAnonymousMystery" alignment="CENTER" spacing="12.0" style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 20;" visible="false" managed="false">
      <ImageView fitWidth="48" fitHeight="48" preserveRatio="true">
         <image>
            <Image url="@../Images/incognito.png" />
         </image>
      </ImageView>
      <Label text="Danh tính được bảo vệ" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #475569;" />
      <Label text="Người dùng này đã chọn tham gia đấu giá ẩn danh. Mọi thông tin cá nhân và lịch sử hoạt động đều được giữ kín để đảm bảo tính riêng tư." textAlignment="CENTER" wrapText="true" style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-max-width: 320;" />
   </VBox>

   <VBox fx:id="panePublicInfo" alignment="CENTER" spacing="12.0" style="-fx-background-color: #F0F9FF; -fx-border-color: #BAE6FD; -fx-border-width: 1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 20;" visible="false" managed="false">
      <Label text="👤" style="-fx-font-size: 48px;" />
      <Label text="Hồ sơ công khai" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0369A1;" />
      <Label text="Bạn đang xem thông tin công khai của người dùng này. Các thông tin liên hệ nhạy cảm và số dư ví được ẩn đi để bảo vệ quyền riêng tư cá nhân." textAlignment="CENTER" wrapText="true" style="-fx-text-fill: #0C4A6E; -fx-font-size: 12px; -fx-max-width: 320;" />
   </VBox>

   <Separator fx:id="separator1" />

   <VBox fx:id="accountInfoSection" spacing="16.0">
      <HBox fx:id="accountInfoTitleBox" alignment="CENTER_LEFT">
         <children>
            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #334155;" text="Thông tin tài khoản" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnEditProfile" onAction="#handleEditProfile" styleClass="button-secondary, button-mini" text="Sửa hồ sơ" />
         </children>
      </HBox>

      <VBox spacing="15.0" style="-fx-background-color: #F8FAFC; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-border-radius: 12;">
         <GridPane fx:id="gridAccountInfo" hgap="20" vgap="15">
            <columnConstraints>
               <ColumnConstraints minWidth="130" prefWidth="130" />
               <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label fx:id="lblEmailTitle" style="-fx-text-fill: #64748B; -fx-font-size: 13px;" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <StackPane alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
               <Label fx:id="lblEmail" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;" text="email@example.com" />
               <TextField fx:id="txtEmail" visible="false" />
            </StackPane>

            <Label fx:id="lblPhoneTitle" style="-fx-text-fill: #64748B; -fx-font-size: 13px;" text="Số điện thoại:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <StackPane alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <Label fx:id="lblPhone" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;" text="0123456789" />
               <TextField fx:id="txtPhone" visible="false" />
            </StackPane>

            <Label fx:id="lblDOBTitle" style="-fx-text-fill: #64748B; -fx-font-size: 13px;" text="Ngày sinh:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <StackPane alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="2">
               <Label fx:id="lblDOB" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;" text="01/01/2000" />
               <DatePicker fx:id="dpDOB" visible="false" maxWidth="Infinity" />
            </StackPane>

            <Label fx:id="lblBalanceTitle" style="-fx-text-fill: #64748B; -fx-font-size: 13px;" text="Số dư khả dụng:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <Label fx:id="lblBalance" style="-fx-font-weight: bold; -fx-text-fill: #15803D; -fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label fx:id="lblLockedBalanceTitle" style="-fx-text-fill: #64748B; -fx-font-size: 13px;" text="Số dư bị khóa:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <Label fx:id="lblLockedBalance" style="-fx-font-weight: bold; -fx-text-fill: #B91C1C; -fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label fx:id="lblPendingStatusLabel" style="-fx-text-fill: #64748B; -fx-font-size: 13px;" text="Trạng thái nâng cấp:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <Label fx:id="lblPendingStatus" style="-fx-font-weight: bold; -fx-text-fill: #0891B2;" text="Đang chờ duyệt Seller" GridPane.columnIndex="1" GridPane.rowIndex="5" />
         </GridPane>
         
         <VBox spacing="10.0">
            <Button fx:id="btnApproveSeller" onAction="#handleApproveSeller" maxWidth="Infinity" styleClass="button-primary" style="-fx-background-color: #059669;" text="✅ Phê duyệt làm Seller" />
            <Button fx:id="btnRevokeSeller" onAction="#handleRevokeSeller" maxWidth="Infinity" styleClass="button-primary" style="-fx-background-color: #DC2626;" text="⛔ Hủy quyền Seller" managed="false" visible="false" />
            <Button fx:id="btnChangePassword" onAction="#handleChangePassword" maxWidth="Infinity" styleClass="button-change-password" text="🛡 Thay đổi mật khẩu" />
         </VBox>
      </VBox>
   </VBox>

   <Separator fx:id="separator2" />

   <VBox fx:id="statsSection" spacing="12.0">
      <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #64748B;" text="Hoạt động trên hệ thống" />

      <HBox spacing="10.0">
         <VBox alignment="CENTER" spacing="4.0" style="-fx-background-color: #EFF6FF; -fx-padding: 14; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
            <Label fx:id="lblStat1Value" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1D4ED8;" text="0" />
            <Label fx:id="lblStat1Label" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="Phiên đã tạo" />
         </VBox>

         <VBox alignment="CENTER" spacing="4.0" style="-fx-background-color: #F0FDF4; -fx-padding: 14; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
            <Label fx:id="lblStat2Value" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #15803D;" text="0" />
            <Label fx:id="lblStat2Label" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="Lượt bid" />
         </VBox>

         <VBox alignment="CENTER" spacing="4.0" style="-fx-background-color: #FDF4FF; -fx-padding: 14; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
            <Label fx:id="lblStat3Value" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #7E22CE;" text="0" />
            <Label fx:id="lblStat3Label" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="Phiên thắng" />
         </VBox>
      </HBox>
   </VBox>

   <Region VBox.vgrow="ALWAYS" />

   <HBox alignment="CENTER_RIGHT">
      <Button onAction="#handleClose" prefHeight="36.0" prefWidth="100.0" styleClass="button-primary" text="Đóng" />
   </HBox>

</VBox>
